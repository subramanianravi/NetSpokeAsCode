# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is excluded by .gitignore.

# ── Netskope Tenant ───────────────────────────────────────────────────────────
netskope_tenant    = "acme.goskope.com"
netskope_api_token = "YOUR_API_TOKEN_HERE"

# ── Tunnels ───────────────────────────────────────────────────────────────────
tunnel_name   = "hq-to-netskope"
tunnel_type   = "ipsec"          # ipsec | gre
primary_pop   = "US-SJC1"
secondary_pop = "US-LAX1"       # leave empty to disable HA
tunnel_psk    = "CHANGE_ME_PSK"
cpe_ip        = "203.0.113.10"  # public IP of your CPE or NGFW

# ── ZTNA / Private Access ─────────────────────────────────────────────────────
private_app_name     = "internal-jira"
private_app_host     = "jira.internal.acme.com"
private_app_protocol = "tcp"
private_app_port     = 443
publisher_name       = "hq-publisher-1"

# ── Security Policies ─────────────────────────────────────────────────────────
policy_name         = "block-social-media"
policy_action       = "block"            # allow | block | alert
source_users        = ["all-users"]
destination_domains = ["facebook.com", "instagram.com", "tiktok.com"]
dlp_profile         = ""                 # leave empty to skip DLP attachment

# ── Steering ──────────────────────────────────────────────────────────────────
steering_config_name = "default-steering"
steering_mode        = "client"          # client | tunnel
steering_exceptions  = ["8.8.8.8", "internal.acme.com"]
